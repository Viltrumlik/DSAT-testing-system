# Standalone exam-runner backend env. Copy to `.env` and fill SECRET_KEY.
# DEBUG=True flips the app into single-process local mode:
#   - SQLite (no DATABASE_URL), LocMem cache (no REDIS_URL),
#   - inline exam scoring (EXAMS_SCORE_INLINE_IF_NO_CELERY defaults to DEBUG),
#   - classroom/assessment shared-cache enforcement off.
DEBUG=True
SECRET_KEY=change-me-generate-with-python-secrets-token_urlsafe-50

ALLOWED_HOSTS=localhost,127.0.0.1

# Leave empty for local SQLite (backend/db.sqlite3). Set for Postgres in prod.
DATABASE_URL=
DB_SSL=False

# Leave empty for in-process LocMem cache.
REDIS_URL=

# Leave empty so exam attempts score inline (no Celery worker / broker needed).
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=False
EXAMS_SCORE_INLINE_IF_NO_CELERY=True

# Frontend dev origin (Next.js on :3000). localhost is auto-trusted in DEBUG.
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS_EXTRA=http://localhost:3000

# Optional: Google OAuth web client id (login). Leave blank to skip Google sign-in.
GOOGLE_CLIENT_ID=
