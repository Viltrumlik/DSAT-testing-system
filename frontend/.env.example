# Standalone exam-runner frontend env. Copy to `.env.local`.
#
# The app calls a RELATIVE `/api` base (src/lib/api.ts). In dev, next.config.ts
# rewrites `/api/*` to API_PROXY_TARGET. Point it at the local Django backend.
API_PROXY_TARGET=http://localhost:8000

# Optional. Leave blank to use the dev proxy. Set to an absolute URL only if you
# want the browser to call the API directly (then configure CORS on the backend).
# NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Optional: Desmos graphing calculator API key (falls back to a built-in
# scientific calculator if unset / CDN unavailable).
NEXT_PUBLIC_DESMOS_API_KEY=

# Optional: Google OAuth web client id for sign-in (must match backend GOOGLE_CLIENT_ID).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
